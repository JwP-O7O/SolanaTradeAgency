# ===================================
# JwP Solana Trading Agency - Environment Configuration
# ===================================

# === TRADING MODE ===
# Options: 'paper' (simulated) or 'live' (real trading)
MODE=paper

# === MONITORING ===
# Interval for checking DEX Screener (milliseconds)
MONITORING_INTERVAL=30000

# === FILTERS ===
# Minimum liquidity for tokens ($USD)
MIN_LIQUIDITY=5000

# Minimum 24h volume ($USD)
MIN_VOLUME_24H=10000

# === TELEGRAM NOTIFICATIONS (Optional) ===
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your-chat-id

# === LOGGING ===
# Log level: 'error', 'warn', 'info', 'debug'
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# ===================================
# LIVE TRADING ONLY (Optional)
# ⚠️ Only fill these in when you're ready for live trading!
# ===================================

# Solana RPC URL (e.g., from Helius, QuickNode, or Alchemy)
# RPC_URL=your-solana-rpc-url

# Wallet private key (⚠️ KEEP THIS SECRET!)
# WALLET_PRIVATE_KEY=your-wallet-private-key

# Helius API key (optional, for enhanced data)
# HELIUS_API_KEY=your-helius-api-key

# ===================================
# ADVANCED SETTINGS (Optional)
# ===================================

# Maximum open positions
# MAX_OPEN_POSITIONS=5

# Portfolio risk limit (% of total)
# MAX_PORTFOLIO_RISK=10

# Minimum confidence for trades (0-1)
# MIN_TRADE_CONFIDENCE=0.70

# Dashboard port (if using web dashboard)
# DASHBOARD_PORT=3000
